{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KernelOn",
  "version": "0.1.0",
  "identifier": "com.kernelon.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:3002",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KernelOn",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
